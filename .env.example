MONGODB_URI=mongodb://localhost:27017/e-stock
# Optionnel — latence élevée / Atlas en veille (valeurs par défaut déjà relevées dans lib/db.ts)
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=45000
# MONGODB_CONNECT_TIMEOUT_MS=30000
# MONGODB_SOCKET_TIMEOUT_MS=120000
NEXTAUTH_SECRET=your-super-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Resend — alertes stock (emails)
RESEND_API_KEY=re_replace_with_your_key
RESEND_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=e-Restaurant
